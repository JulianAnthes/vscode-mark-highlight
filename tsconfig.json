{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "Preserve",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node", "vscode", "mocha"]
    },
    "include": ["src", "vitest.config.ts"],
    "exclude": ["node_modules", "dist", "examples"]
}
